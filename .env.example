# ==============================================================================
# KnowledgeForge AI Platform - Global Environment Configuration
# ==============================================================================

# Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth2 Credentials (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Signature Key (Minimum 256 bits, HS256)
JWT_SECRET_KEY=32_bytes_long_random_hex_string_for_security_keys_here

# AWS / MinIO Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_S3_BUCKET=your_s3_bucket_here
AWS_REGION=your_aws_region_here

# SMTP Configuration (Default points to MailHog)
SPRING_MAIL_HOST=your_smtp_host_here
SPRING_MAIL_PORT=your_smtp_port_here
SPRING_MAIL_USERNAME=your_smtp_username_here
SPRING_MAIL_PASSWORD=your_smtp_password_here

# Service Default Profiles
SPRING_PROFILES_ACTIVE=dev

# Microsoft Foundry IQ (Azure AI Search & Project) Integration
USE_FOUNDRY_IQ=false
AZURE_AI_SEARCH_ENDPOINT=your_azure_ai_search_endpoint_here
AZURE_AI_SEARCH_KEY=your_azure_ai_search_key_here
AZURE_AI_PROJECT_ENDPOINT=your_azure_ai_project_endpoint_here
AZURE_AI_MODEL_DEPLOYMENT_NAME=your_azure_ai_model_deployment_name_here

